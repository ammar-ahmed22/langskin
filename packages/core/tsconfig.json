{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    "strict": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": true,

    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@core/*": ["./*"],
      "@langskin": ["./src/index"],
      "@langskin/*": ["./src/*"],
      "@cli/*": ["./src/cli/*"],
      "@test/*": ["./test/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["dist"]
}
