{
  "name": "langskin",
  "version": "0.4.0",
  "description": "A customizable programming language interpreter that lets you redefine keywords via a simple JSON map",
  "license": "MIT",
  "homepage": "https://github.com/ammar-ahmed22/langskin/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ammar-ahmed22/langskin.git",
    "directory": "packages/core"
  },
  "keywords": [
    "language",
    "syntax",
    "parser",
    "compiler",
    "dsl"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "langskin": "./dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "dev:cli": "tsx src/cli/index.ts",
    "start:cli": "pnpm run build && node dist/cli.cjs",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "bump:patch": "npm version patch",
    "bump:minor": "npm version minor",
    "bump:major": "npm version major",
    "publish:npm": "npm publish --access public"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@types/node": "^25.3.5",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "pretty-ms": "^9.3.0",
    "zod": "^4.3.6"
  }
}
